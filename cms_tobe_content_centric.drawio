        <mxCell id="complete" value="&lt;b style='color:#0071E3;font-size:12px'&gt;✓ 콘텐츠 완성 — 여기까지 서비스와 무관합니다&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FF;strokeColor=#0071E3;strokeWidth=1.5;arcSize=50;" vertex="1" parent="1">
