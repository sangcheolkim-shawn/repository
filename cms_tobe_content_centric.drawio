        <mxCell id="zone_svc_label" value="&lt;b style='color:#1B8A3E;font-size:11px;letter-spacing:1px'&gt;서비스 연결 — &quot;어디로 보낼지&quot; 결정&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
