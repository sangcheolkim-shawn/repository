        <mxCell id="zone_svc" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=rgba(27,138,62,0.04);strokeColor=#1B8A3E;strokeWidth=1;dashed=1;dashPattern=6 4;arcSize=4;" vertex="1" parent="1">
