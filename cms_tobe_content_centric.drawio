        <!-- Step 4: 서비스 연결 -->
        <mxCell id="step4" value="&lt;div style='text-align:center'&gt;&lt;span style='background:rgba(255,255,255,0.2);border-radius:50%;width:28px;height:28px;display:inline-block;line-height:28px;font-size:14px;font-weight:800;color:#fff'&gt;4&lt;/span&gt;&lt;/div&gt;&lt;b style='font-size:13px;color:#fff'&gt;서비스 연결&lt;/b&gt;&lt;hr style='border-color:rgba(255,255,255,0.2)'&gt;&lt;font color='rgba(255,255,255,0.85)' style='font-size:10px'&gt;같은 콘텐츠에 &quot;라벨&quot;만 다르게 붙인다&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color='rgba(255,255,255,0.7)' style='font-size:9px'&gt;정답·해설 → ND 뉴드림스&lt;br&gt;정답·해설 → NH 눈높이 (별칭: &quot;우리아이 수학 해답지&quot;)&lt;br&gt;핵심점검 → SJ 성장판 (자유 depth 매핑)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B8A3E;strokeColor=none;arcSize=8;verticalAlign=top;spacingTop=8;spacingLeft=10;" vertex="1" parent="1">
