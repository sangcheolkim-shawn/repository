  <diagram id="tobe" name="콘텐츠 중심 체계 (To-Be)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b style='font-size:18px'&gt;콘텐츠 중심 관리 체계 (To-Be)&lt;/b&gt;&lt;br&gt;&lt;font color='#8E8E93' style='font-size:11px'&gt;콘텐츠를 먼저 만들고, 서비스 연결은 나중에&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- 콘텐츠 제작 영역 (파란 점선 영역) -->
        <mxCell id="zone_content" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=rgba(0,113,227,0.04);strokeColor=#0071E3;strokeWidth=1;dashed=1;dashPattern=6 4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="620" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="zone_content_label" value="&lt;b style='color:#0071E3;font-size:11px;letter-spacing:1px'&gt;콘텐츠 제작 영역 — 서비스를 신경 쓰지 않습니다&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="85" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- Step 1: 양식 정의 -->
        <mxCell id="step1" value="&lt;div style='text-align:center'&gt;&lt;span style='background:rgba(255,255,255,0.2);border-radius:50%;width:28px;height:28px;display:inline-block;line-height:28px;font-size:14px;font-weight:800;color:#fff'&gt;1&lt;/span&gt;&lt;/div&gt;&lt;b style='font-size:13px;color:#fff'&gt;양식 정의&lt;/b&gt;&lt;hr style='border-color:rgba(255,255,255,0.2)'&gt;&lt;font color='rgba(255,255,255,0.85)' style='font-size:9px'&gt;&quot;뭘 넣을지 정한다&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='rgba(255,255,255,0.7)' style='font-size:9px'&gt;· 정답·해설&lt;br&gt;· 자동채점&lt;br&gt;· 핵심점검&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0071E3;strokeColor=none;arcSize=8;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="115" width="170" height="145" as="geometry"/>
        </mxCell>

        <!-- Step 2: 커리큘럼 설계 -->
        <mxCell id="step2" value="&lt;div style='text-align:center'&gt;&lt;span style='background:rgba(255,255,255,0.2);border-radius:50%;width:28px;height:28px;display:inline-block;line-height:28px;font-size:14px;font-weight:800;color:#fff'&gt;2&lt;/span&gt;&lt;/div&gt;&lt;b style='font-size:13px;color:#fff'&gt;커리큘럼 설계&lt;/b&gt;&lt;hr style='border-color:rgba(255,255,255,0.2)'&gt;&lt;font color='rgba(255,255,255,0.85)' style='font-size:9px'&gt;&quot;구조를 자유롭게 설계&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='rgba(255,255,255,0.7)' style='font-size:9px'&gt;· depth 제한 없음&lt;br&gt;· 트리 편집기&lt;br&gt;· 가져오기 지원&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0071E3;strokeColor=none;arcSize=8;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="115" width="170" height="145" as="geometry"/>
        </mxCell>

        <!-- Step 3: 콘텐츠 입력 -->
        <mxCell id="step3" value="&lt;div style='text-align:center'&gt;&lt;span style='background:rgba(255,255,255,0.2);border-radius:50%;width:28px;height:28px;display:inline-block;line-height:28px;font-size:14px;font-weight:800;color:#fff'&gt;3&lt;/span&gt;&lt;/div&gt;&lt;b style='font-size:13px;color:#fff'&gt;콘텐츠 입력&lt;/b&gt;&lt;hr style='border-color:rgba(255,255,255,0.2)'&gt;&lt;font color='rgba(255,255,255,0.85)' style='font-size:9px'&gt;&quot;데이터를 입력한다&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='rgba(255,255,255,0.7)' style='font-size:9px'&gt;· 세트별 입력&lt;br&gt;· 진행률 표시&lt;br&gt;· 칸반 보드&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0071E3;strokeColor=none;arcSize=8;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="115" width="160" height="145" as="geometry"/>
        </mxCell>

