        <mxCell id="to-arr4" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#43A047;" edge="1" parent="1" source="to-4" target="to-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-5" value="&lt;b&gt;5. 원클릭 배포&lt;/b&gt;&lt;br&gt;&lt;font color='#666'&gt;다중 시스템 동시 배포&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="625" width="240" height="55" as="geometry" />
