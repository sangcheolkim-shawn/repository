        <!-- TO-BE Summary -->
        <mxCell id="to-summary" value="5단계 · 엑셀 제거 · 자체 배포 · 콘텐츠 독립 아키텍처" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#FFFFFF;strokeColor=#1B5E20;fontSize=13;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
