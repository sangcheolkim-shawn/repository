        <mxCell id="ben-5" value="&#9989; 스케줄 배포&lt;br&gt;배포 이력 자동 관리" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2FF59;strokeColor=#64DD17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
