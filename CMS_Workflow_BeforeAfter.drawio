  <diagram id="workflow-comparison" name="AS-IS vs TO-BE 워크플로우 비교">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="main-title" value="CMS 워크플로우 비교: AS-IS vs TO-BE" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;fontColor=#1A1A2E;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- ========== AS-IS (좌측) ========== -->
        <mxCell id="asis-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;arcSize=6;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="820" height="870" as="geometry" />
        </mxCell>
        <mxCell id="asis-header" value="AS-IS (현행)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fontColor=#C62828;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="asis-pain" value="수작업 중심 · 과목별 양식 분리 · 반복 작업 다수" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fontColor=#D32F2F;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="200" y="132" width="400" height="20" as="geometry" />
        </mxCell>

        <!-- AS-IS Steps -->
        <mxCell id="as-1" value="&lt;b&gt;1. 과목코드 확인&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;JiniWorks에서 수동 조회&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="170" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="as-arr1" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-1" target="as-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-2" value="&lt;b&gt;2. 양식 결정&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;과목별로 별도 양식 생성 필요&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="250" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- Pain Point Callout -->
        <mxCell id="pain-1" value="&#10060; 국어_해답지, 영어_해답지...&lt;br&gt;과목마다 양식 증가!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEB3B;strokeColor=#F57F17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="250" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pain-1-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#F57F17;dashed=1;" edge="1" parent="1" source="as-2" target="pain-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-arr2" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-2" target="as-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-3" value="&lt;b&gt;3. 엑셀 데이터 입력&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;오프라인 엑셀 작업 후 업로드&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="330" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="pain-2" value="&#10060; 엑셀 오류 빈번&lt;br&gt;버전 관리 불가" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEB3B;strokeColor=#F57F17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="335" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="pain-2-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#F57F17;dashed=1;" edge="1" parent="1" source="as-3" target="pain-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-arr3" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-3" target="as-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-4" value="&lt;b&gt;4. 검수 요청&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;메일/메신저로 수동 요청&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="415" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="as-arr4" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-4" target="as-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-5" value="&lt;b&gt;5. 과목코드 직접 매핑&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;개발팀 요청 → DB 직접 수정&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="500" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="pain-3" value="&#10060; 개발팀 의존&lt;br&gt;리드타임 1~2주" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEB3B;strokeColor=#F57F17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="505" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="pain-3-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#F57F17;dashed=1;" edge="1" parent="1" source="as-5" target="pain-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-arr5" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-5" target="as-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-6" value="&lt;b&gt;6. 시스템별 수동 배포&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;시스템마다 개별 배포 작업&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="585" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="as-arr6" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#E53935;" edge="1" parent="1" source="as-6" target="as-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="as-7" value="&lt;b&gt;7. 결과 확인&lt;/b&gt;&lt;br&gt;&lt;font color='#999'&gt;각 시스템 직접 접속 확인&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="670" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- AS-IS Summary -->
        <mxCell id="as-summary" value="총 7단계 · 엑셀 의존 · 개발팀 병목 · 과목별 양식 증가" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E53935;fontColor=#FFFFFF;strokeColor=#B71C1C;fontSize=13;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="760" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Duration -->
        <mxCell id="as-duration" value="평균 소요 시간: &lt;b&gt;3~4주&lt;/b&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=middle;fontColor=#C62828;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="280" y="810" width="240" height="30" as="geometry" />
        </mxCell>

        <!-- ========== 중앙 화살표 ========== -->
        <mxCell id="center-arrow" value="" style="shape=mxgraph.arrows2.arrow;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#2E7D32;direction=south;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="878" y="430" width="44" height="100" as="geometry" />
        </mxCell>
        <mxCell id="center-label" value="&lt;b&gt;혁신&lt;/b&gt;" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#2E7D32;fontFamily=Pretendard;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="870" y="460" width="60" height="30" as="geometry" />
        </mxCell>

        <!-- ========== TO-BE (우측) ========== -->
        <mxCell id="tobe-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=6;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="940" y="90" width="820" height="870" as="geometry" />
        </mxCell>
        <mxCell id="tobe-header" value="TO-BE (CMS 2.0)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fontColor=#2E7D32;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="1200" y="100" width="250" height="35" as="geometry" />
        </mxCell>
        <mxCell id="tobe-sub" value="자동화 · 콘텐츠 독립 · 원클릭 배포" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fontColor=#388E3C;fontFamily=Pretendard;" vertex="1" parent="1">
          <mxGeometry x="1100" y="132" width="400" height="20" as="geometry" />
        </mxCell>

        <!-- TO-BE Steps (5단계로 축소) -->
        <mxCell id="to-1" value="&lt;b&gt;1. 커리큘럼 설계&lt;/b&gt;&lt;br&gt;&lt;font color='#666'&gt;트리 편집기로 구조 설계&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="170" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- Benefit Callout -->
        <mxCell id="ben-1" value="&#9989; 시각적 트리 빌더&lt;br&gt;외부 데이터 자동 가져오기" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2FF59;strokeColor=#64DD17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="170" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ben-1-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#64DD17;dashed=1;" edge="1" parent="1" source="to-1" target="ben-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-arr1" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#43A047;" edge="1" parent="1" source="to-1" target="to-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-2" value="&lt;b&gt;2. 양식 구성 (필드 풀)&lt;/b&gt;&lt;br&gt;&lt;font color='#666'&gt;공용 필드 풀에서 조합&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="280" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ben-2" value="&#9989; 유형 고정, 필드만 교체&lt;br&gt;과목별 양식 증가 없음!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2FF59;strokeColor=#64DD17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="280" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ben-2-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#64DD17;dashed=1;" edge="1" parent="1" source="to-2" target="ben-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-arr2" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#43A047;" edge="1" parent="1" source="to-2" target="to-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-3" value="&lt;b&gt;3. 콘텐츠 등록 + 검수&lt;/b&gt;&lt;br&gt;&lt;font color='#666'&gt;칸반 보드에서 작업 추적&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="395" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ben-3" value="&#9989; CMS 내 직접 입력&lt;br&gt;실시간 진척률 확인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2FF59;strokeColor=#64DD17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="395" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ben-3-arr" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#64DD17;dashed=1;" edge="1" parent="1" source="to-3" target="ben-3">
