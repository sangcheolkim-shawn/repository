        <mxCell id="to-arr3" value="" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=2;strokeColor=#43A047;" edge="1" parent="1" source="to-3" target="to-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="to-4" value="&lt;b&gt;4. 과목코드 연결&lt;/b&gt;&lt;br&gt;&lt;font color='#666'&gt;UI에서 직접 바인딩&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#43A047;fontSize=12;fontFamily=Pretendard;align=center;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="510" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ben-4" value="&#9989; 개발팀 의존 제거&lt;br&gt;기획자가 직접 연결" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2FF59;strokeColor=#64DD17;fontSize=11;fontFamily=Pretendard;align=center;fontStyle=1;shadow=1;" vertex="1" parent="1">
