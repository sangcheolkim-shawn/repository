        <mxCell id="step1_desc" value="입력 양식(Form Template) 정의&#xa;대상 시스템별 양식 구성&#xa;유형코드 자동 파생" style="text;fontSize=10;fontColor=#616161;align=left;verticalAlign=top;shadow=0;" vertex="1" parent="1">
